# Copy to .env and fill in.  cp demos/.env.template demos/.env

# ── Required ────────────────────────────────────────────────────────────────
# Your API key. For Azure AI Foundry, this is the resource key.
OPENAI_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# Custom endpoint. Leave unset to hit api.openai.com directly.
# Azure AI Foundry (OpenAI-compatible v1 endpoint):
#   OPENAI_BASE_URL=https://<your-resource>.services.ai.azure.com/openai/v1
# Local proxy / gateway:
#   OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_BASE_URL=

# Model name. For Azure Foundry, this is your *deployment name*, not "gpt-5".
# Defaults to gpt-5-mini if unset.
OPENAI_MODEL=
